# ローカル Supabase（npx supabase start → Studio の API Keys）
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...from-supabase-status

# サーバー専用（Dashboard の Secret Key / service_role）
SUPABASE_SECRET_KEY=sb_secret_...from-supabase-status

# 旧形式 JWT キーも利用可（Publishable / Secret より優先度は低い）
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# クラウド Supabase の場合
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# 取得方法: npx supabase status
# 設定後は npm run dev を再起動してください

# サイト URL（Stripe リダイレクト用）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe（カート・チェックアウト）
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

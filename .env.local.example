# ローカル Supabase（npx supabase start の出力例）
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-status

# クラウド Supabase の場合
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# 取得方法: npx supabase status -o env
# 設定後は npm run dev を再起動してください

# サイト URL（Stripe リダイレクト用）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe（カート・チェックアウト）
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Webhook / 管理操作用（Supabase Dashboard → Settings → API）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Copy to .env.production.supabase and fill with Supabase CLOUD values.
# Get these from https://supabase.com/dashboard → your project → Settings → API
# Do NOT use 127.0.0.1 values (those are local-only).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Optional: Supabase Cloud database password (Dashboard project settings)
# SUPABASE_DB_PASSWORD=your-database-password

# Optional: seed production test logins after migrations
PROD_ADMIN_EMAIL=admin@eldonia-nex.com
PROD_CREATE_EMAIL=create@eldonia-nex.com
PROD_USER_PASSWORD=your-secure-password

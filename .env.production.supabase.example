# Copy to .env.production.supabase and fill with Supabase CLOUD values.
# Get these from https://supabase.com/dashboard → your project → Settings → API
# Do NOT commit .env.production.supabase (gitignored).

SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxx
SUPABASE_PROJECT_REF=evrklfqdyptuelulgcdy

NEXT_PUBLIC_SUPABASE_URL=https://evrklfqdyptuelulgcdy.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# --- さくら SMTP（Supabase Auth 確認メール・パスワードリセット用）---
# SMTP サーバーは初期ドメイン elbonianex.sakura.ne.jp を使用（独自ドメインでも同じ）
SUPABASE_SMTP_HOST=elbonianex.sakura.ne.jp
SUPABASE_SMTP_PORT=587
SUPABASE_SMTP_USER=noreply@elbonianex.sakura.ne.jp
SUPABASE_SMTP_PASS=<noreply メールボックスのパスワード>
# From（自動メール）。SMTP 認証は sakura.ne.jp、表示は独自ドメイン
SUPABASE_SMTP_ADMIN_EMAIL=noreply@eldonia-nex.com
SUPABASE_SMTP_SENDER_NAME=Eldonia Nex
# 確認メール等の時間あたり上限（カスタム SMTP 有効化後も Dashboard で調整可）
SUPABASE_RATE_LIMIT_EMAIL_SENT=60

# --- Google OAuth（Supabase Auth → Providers → Google）---
# Google Cloud Console で Web クライアント ID を作成後に記入
GOOGLE_OAUTH2_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_OAUTH2_CLIENT_SECRET=....
# 反映: npm run supabase:sync-google

# --- Facebook / X / Discord OAuth（npm run supabase:sync-social）---
# 手順: docs/facebook-oauth-setup.md, docs/x-oauth-setup.md, docs/discord-oauth-setup.md
# FACEBOOK_OAUTH_CLIENT_ID=
# FACEBOOK_OAUTH_CLIENT_SECRET=
# X_OAUTH_CLIENT_ID=
# X_OAUTH_CLIENT_SECRET=
# DISCORD_OAUTH_CLIENT_ID=
# DISCORD_OAUTH_CLIENT_SECRET=

# Optional: seed production test logins after migrations
PROD_ADMIN_EMAIL=admin@eldonia-nex.com
PROD_CREATE_EMAIL=create@eldonia-nex.com
PROD_USER_PASSWORD=your-secure-password
